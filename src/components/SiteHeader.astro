---

<header class="site-header">
  <div class="banner-stars">
    {Array.from({length: 20}).map((_, i) => (
      <div class="banner-star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 6}s; --size: ${Math.random() * 2 + 1}px; --brightness: 0.5;`} />
    ))}
    {Array.from({length: 8}).map((_, i) => (
      <div class="banner-star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 6}s; --size: ${Math.random() * 2 + 2}px; --brightness: 1;`} />
    ))}
  </div>
  <nav class="site-nav">
    <a href="/" class="brand">
      <img
        src="/apollonia_logo_white_black.png"
        alt=""
        class="logo"
        width="60"
        height="60"
        fetchpriority="high"
        decoding="async"
      />
      <span class="brand-name">Apollonia Space</span>
    </a>

    <button class="menu-toggle" aria-label="Menu" id="menu-toggle">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="nav-right" id="nav-menu">
      <a href="/" class="nav-link">Home</a>
      <a href="/podcast" class="nav-link">Podcast</a>
      <a href="/about" class="nav-link">About Us</a>
      <a href="/pressnews" class="nav-link">Press &amp; News</a>

      <div class="social-group">
        <a href="https://www.youtube.com/@ApolloniaSpace" target="_blank" rel="noopener" title="YouTube" class="social-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
        </a>

        <a href="https://open.spotify.com/user/31vjkbepayfz4d62kj5ahsujkn3y" target="_blank" rel="noopener" title="Spotify" class="social-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.6-6-2-10-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.3-1 8.1-.6 11.1 1.2.4.2.5.7.3 1.1zm1.5-3.3c-.3.4-.8.5-1.2.3-3-1.9-7.7-2.4-11.3-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.1-1.3 9.2-.7 12.7 1.5.3.2.5.8.3 1.2zm.1-3.4c-3.7-2.2-9.7-2.4-13.2-1.3-.5.2-1.1-.1-1.3-.6-.2-.5.1-1.1.6-1.3 4-1.2 10.7-1 14.9 1.5.5.3.6.9.4 1.4-.3.5-.9.6-1.4.3z"/></svg>
        </a>

        <a href="#" target="_blank" title="Apple Podcasts" class="social-icon apple-fix">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M5.3 17.1c.2.5.4 1 .7 1.6.4.7.7 1.2 1 1.5.4.5.8.8 1.2.9.4.1.9.2 1.4.1.4-.1.8-.2 1.4-.5.5-.3 1-.4 1.5-.4s1 .1 1.5.4c.5.3 1 .4 1.4.5.5.1.9 0 1.3-.2.5-.3.9-.7 1.3-1.3.3-.4.6-.9.9-1.5.3-.7.6-1.4.7-2-.1 0-.5-.2-1.1-.5-.6-.3-1.1-.8-1.5-1.4-.4-.6-.7-1.4-.7-2.2 0-1 .3-1.8.9-2.5.3-.4.7-.7 1.2-1-0.7-1-1.7-1.5-2.9-1.6-.5 0-1.2.2-1.9.5-.7.3-1.1.5-1.3.5-.3 0-.7-.2-1.3-.5-.6-.3-1.1-.4-1.6-.5h-.3c-.8.1-1.6.4-2.3 1-.7.6-1.2 1.3-1.5 2.2-.4 1-.5 2.1-.4 3.2.1 1.1.4 2.3.9 3.4zM12 5.5c.3-1 .9-1.8 1.7-2.5.8-.7 1.7-1 2.6-1.1 0 1-.3 2-1 2.8-.7.9-1.6 1.4-2.7 1.5-.3 0-.5-.2-.6-.7z"/></svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  function initMenu() {
    const menuToggle = document.getElementById('menu-toggle');
    const navMenu = document.getElementById('nav-menu');

    if (!menuToggle || !navMenu) return;

    // Schließe Menü nach Navigation (Header persistiert, also bleibt Open-State sonst kleben)
    navMenu.classList.remove('open');
    menuToggle.classList.remove('active');

    // Listener nur einmal anhängen — Header ist persistent, DOM bleibt gleich
    if (menuToggle.dataset.menuInit === 'true') return;
    menuToggle.dataset.menuInit = 'true';

    menuToggle.addEventListener('click', () => {
      navMenu.classList.toggle('open');
      menuToggle.classList.toggle('active');
    });

    // Bonus: tap auf einen Nav-Link schließt das Menü sofort
    navMenu.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) {
        navMenu.classList.remove('open');
        menuToggle.classList.remove('active');
      }
    });
  }

  document.addEventListener('astro:page-load', initMenu);
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    background: #000000;
    overflow: visible;
  }

  .site-header::after {
    content: '';
    position: absolute;
    bottom: -60px;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, #000000, transparent);
    pointer-events: none;
  }

  .banner-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .banner-star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: #ffffff;
    border-radius: 50%;
    opacity: 0;
    animation: starTwinkle 8s var(--delay) infinite ease-in-out;
  }

  @keyframes starTwinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: var(--brightness, 0.8); }
  }

  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 3rem 0.8rem 2rem;
    position: relative;
    z-index: 1;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #ffffff;
  }

  .logo {
    height: 60px;
    width: auto;
    display: block;
  }

  .brand-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-right {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 1rem;
  }

  .social-group {
    display: flex;
    flex-direction: row;
    align-items: center;
    flex-wrap: nowrap;
    gap: 1rem;
  }

  .nav-link {
    color: #ffffff;
    text-decoration: none;
    font-size: 1rem;
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04 em;
    text-shadow: 0 0 1px rgba(255, 255, 255, 0.5);
    transition: color 0.3s, border-color 0.3s;
    border-bottom: 2px solid transparent;
    padding-bottom: 4px;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: #42A5F5;
    border-bottom: 2px solid #42A5F5;
  }

  .social-icon {
    color: #ffffff;
    text-decoration: none;
    text-shadow: 0 0 1px rgba(255, 255, 255, 0.5);
    transition: color 0.3s;
    display: flex;
    align-items: center;
    transform: translateY(-2px);
  }

  .social-icon:hover {
    color: #42A5F5;
  }

  .social-icon.apple-fix {
    margin-left: -4px;
    margin-right: -4px;
    transform: translateY(-3px);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    position: relative;
    z-index: 100;
    width: 40px;
    height: 40px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: #ffffff;
    transition: all 0.3s;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  /* Auf etwas schmaleren Desktops vor dem Mobile-Breakpoint:
     Schrift leicht verkleinern, damit alle 4 Links + Socials in eine Reihe passen */
  @media (max-width: 1100px) and (min-width: 769px) {
    .nav-link {
      font-size: 0.9rem;
      letter-spacing: 0.08em;
    }

    .nav-right {
      gap: 0.85rem;
    }

    .site-nav {
      padding: 0.8rem 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .site-nav {
      padding: 0.6rem 1.2rem;
    }

    .logo {
      height: 42px;
    }

    .brand-name {
      font-size: 0.95rem;
    }

    .menu-toggle {
      display: flex;
    }

    .nav-right {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 75%;
      max-width: 300px;
      background: #000000;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      padding: 5rem 2rem 2rem;
      gap: 1.5rem;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }

    .nav-right.open {
      transform: translateX(0);
    }

    .nav-link {
      font-size: 1.1rem;
      width: 100%;
      padding: 0.5rem 0;
    }

    .social-group {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      width: 100%;
      gap: 1.5rem;
    }
  }

  @media (max-width: 380px) {
    .brand-name {
      display: none;
    }
  }
</style>