---
// SiteHeader.astro
---

<header class="site-header">
  <div class="banner-stars">
    {Array.from({length: 20}).map((_, i) => (
      <div class="banner-star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 6}s; --size: ${Math.random() * 2 + 1}px; --brightness: 0.5;`} />
    ))}
    {Array.from({length: 8}).map((_, i) => (
      <div class="banner-star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 6}s; --size: ${Math.random() * 2 + 2}px; --brightness: 1;`} />
    ))}
  </div>
  <nav class="site-nav">
    <a href="/" class="brand">
      <img
        src="/apollonia_logo_white_black.png"
        alt=""
        class="logo"
        width="60"
        height="60"
        fetchpriority="high"
        decoding="async"
      />
      <span class="brand-name">Apollonia Space</span>
    </a>

    <button class="menu-toggle" aria-label="Menu" id="menu-toggle">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="nav-right" id="nav-menu">
      <a href="/" class="nav-link">Home</a>
      <a href="/technology" class="nav-link">Technology</a>
      <a href="/podcast" class="nav-link">Podcast</a>
      <a href="/about" class="nav-link">About Us</a>
      <a href="/pressnews" class="nav-link">Press & News</a>
    </div>
  </nav>
</header>

<script>
  function initMenu() {
    const menuToggle = document.getElementById('menu-toggle');
    const navMenu = document.getElementById('nav-menu');

    if (!menuToggle || !navMenu) return;

    // Close menu on new page load navigation
    navMenu.classList.remove('open');
    menuToggle.classList.remove('active');

    if (menuToggle.dataset.menuInit === 'true') return;
    menuToggle.dataset.menuInit = 'true';

    menuToggle.addEventListener('click', () => {
      navMenu.classList.toggle('open');
      menuToggle.classList.toggle('active');
    });

    navMenu.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) {
        navMenu.classList.remove('open');
        menuToggle.classList.remove('active');
      }
    });
  }

  document.addEventListener('astro:page-load', initMenu);
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    background: #000000;
    overflow: visible;
  }

  .site-header::after {
    content: '';
    position: absolute;
    bottom: -60px;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, #000000, transparent);
    pointer-events: none;
  }

  .banner-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .banner-star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: #ffffff;
    border-radius: 50%;
    opacity: 0;
    animation: starTwinkle 8s var(--delay) infinite ease-in-out;
  }

  @keyframes starTwinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: var(--brightness, 0.8); }
  }

  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 3rem 0.8rem 2rem;
    position: relative;
    z-index: 1;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #ffffff;
  }

  .logo {
    height: 60px;
    width: auto;
    display: block;
  }

  .brand-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-right {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 1.5rem;
  }

  .nav-link {
    color: #ffffff;
    text-decoration: none;
    font-size: 1rem;
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-shadow: 0 0 1px rgba(255, 255, 255, 0.5);
    transition: color 0.3s, border-color 0.3s;
    border-bottom: 2px solid transparent;
    padding-bottom: 4px;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: #42A5F5;
    border-bottom: 2px solid #42A5F5;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    position: relative;
    z-index: 100;
    width: 40px;
    height: 40px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: #ffffff;
    transition: all 0.3s;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  /* Font adaptation rules for modern medium width desktop scales */
  @media (max-width: 1100px) and (min-width: 769px) {
    .nav-link {
      font-size: 0.85rem;
      letter-spacing: 0.06em;
    }

    .nav-right {
      gap: 1rem;
    }

    .site-nav {
      padding: 0.8rem 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .site-nav {
      padding: 0.6rem 1.2rem;
    }

    .logo {
      height: 42px;
    }

    .brand-name {
      font-size: 0.95rem;
    }

    .menu-toggle {
      display: flex;
    }

    .nav-right {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: 75%;
      max-width: 300px;
      background: #000000;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      padding: 5rem 2rem 2rem;
      gap: 1.5rem;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }

    .nav-right.open {
      transform: translateX(0);
    }

    .nav-link {
      font-size: 1.1rem;
      width: 100%;
      padding: 0.5rem 0;
    }
  }

  @media (max-width: 380px) {
    .brand-name {
      display: none;
    }
  }
</style>