---
interface Props {
  current?: 'podcast' | 'about';
}

const { current } = Astro.props;

const links = [
  { href: '/podcast', label: 'Podcast', id: 'podcast' as const },
  { href: '/about', label: 'About Us', id: 'about' as const },
  { href: '/#imprint', label: 'Imprint', id: null },
];
---

<header class="site-header">
  <nav class="site-nav" aria-label="Main navigation">
    <a href="/" class="brand" aria-label="Apollonia Space, home">
      <img src="/apollonia_mark_dark.png" alt="" class="logo" width="72" height="72" />
      <span class="brand-name">Apollonia Space</span>
    </a>
    <ul class="nav-links">
      {links.map(({ href, label, id }) => (
        <li>
          <a
            href={href}
            aria-current={id && current === id ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 0;
    background: var(--banner-bg);
    border-bottom: 1px solid rgba(232, 213, 183, 0.2);
    overflow: hidden;
  }

  .site-header::before {
    content: '';
    position: absolute;
    right: -8%;
    bottom: -55%;
    width: 50%;
    height: 140%;
    background-image:
      radial-gradient(circle, rgba(120, 210, 200, 0.55) 1px, transparent 1px),
      radial-gradient(circle, rgba(120, 210, 200, 0.35) 1.5px, transparent 1.5px);
    background-size: 7px 8px, 11px 12px;
    background-position: 0 0, 4px 5px;
    opacity: 0.45;
    mask-image: radial-gradient(ellipse 75% 70% at 85% 75%, black 15%, transparent 72%);
    pointer-events: none;
  }

  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    position: relative;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    align-self: center;
    margin: 0.45rem 0 0.45rem 0.75rem;
    text-decoration: none;
    color: var(--cream);
    position: relative;
    z-index: 1;
  }

  .brand:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: 4px;
    box-shadow: 0 0 0 6px rgba(196, 164, 110, 0.55);
    border-radius: 2px;
  }

  .logo {
    height: clamp(56px, 7vw, 72px);
    width: auto;
    display: block;
  }

  .brand-name {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(0.75rem, 1.8vw, 1rem);
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    align-items: stretch;
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 1;
    border-left: 1px solid rgba(232, 213, 183, 0.45);
    border-top: 1px solid rgba(232, 213, 183, 0.45);
    border-bottom: 1px solid rgba(232, 213, 183, 0.45);
  }

  .nav-links a {
    display: flex;
    align-items: center;
    height: 100%;
    min-height: 3.25rem;
    padding: 0 2.25rem;
    color: var(--cream-pale);
    text-decoration: none;
    font-size: 0.95rem;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border-left: 1px solid rgba(232, 213, 183, 0.45);
    transition: background 0.2s, color 0.2s, box-shadow 0.2s;
  }

  .nav-links li:first-child a {
    border-left: none;
  }

  .nav-links li:last-child a {
    border-right: 1px solid rgba(232, 213, 183, 0.45);
  }

  .nav-links a:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
  }

  .nav-links a:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: 2px;
    background: rgba(255, 255, 255, 0.22);
    color: #ffffff;
    box-shadow:
      inset 0 0 0 2px var(--accent),
      0 0 0 4px rgba(196, 164, 110, 0.55);
    z-index: 2;
    position: relative;
  }

  .nav-links a[aria-current='page'] {
    background: rgba(255, 255, 255, 0.16);
    color: #ffffff;
    box-shadow: inset 0 -3px 0 var(--accent);
  }
</style>
