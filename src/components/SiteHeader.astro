---
---

<header class="site-header">
  <div class="banner-stars">
    {Array.from({length: 25}).map((_, i) => (
      <div class="banner-star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 4}s; --size: ${Math.random() * 2 + 1}px;`} />
    ))}
  </div>
  <nav class="site-nav">
    <a href="/" class="brand">
    <img src="/apollonia_mark_dark.png" alt="" class="logo" />
      <span class="brand-name">Apollonia Space</span>
    </a>
    <div class="nav-links">
      <a href="/podcast">Podcast</a>
      <a href="/about">About Us</a>
      <a href="/#imprint">Imprint</a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    background: #000000;
    overflow: hidden;
  }

  .banner-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .banner-star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: #ffffff;
    border-radius: 50%;
    opacity: 0;
    animation: starTwinkle 4s var(--delay) infinite ease-in-out;
  }

  @keyframes starTwinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.8; }
  }

  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 3rem 0.8rem 4rem;
    position: relative;
    z-index: 1;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #ffffff;
  }

  .logo {
    height: clamp(56px, 7vw, 72px);
    width: auto;
    display: block;
  }

  .brand-name {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    color: #ffffff;
    text-decoration: none;
    font-size: 1rem;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: color 0.3s;
  }

  .nav-links a:hover {
    color: #42A5F5;
  }
</style>