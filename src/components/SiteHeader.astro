<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    background: #000000;
    overflow: visible;
  }

  .site-header::after {
    content: '';
    position: absolute;
    bottom: -60px;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, #000000, transparent);
    pointer-events: none;
  }

  .banner-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .banner-star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: #ffffff;
    border-radius: 50%;
    opacity: 0;
    animation: starTwinkle 8s var(--delay) infinite ease-in-out;
  }

  @keyframes starTwinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: var(--brightness, 0.8); }
  }

  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 3rem 0.8rem 2rem;
    position: relative;
    z-index: 1;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #ffffff;
  }

  .logo {
    height: clamp(56px, 7vw, 72px);
    width: auto;
    display: block;
  }

  .brand-name {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-link {
    color: #ffffff;
    text-decoration: none;
    font-size: 1rem;
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-shadow: 0 0 1px rgba(255, 255, 255, 0.5);
    transition: color 0.3s, border-color 0.3s;
    border-bottom: 2px solid transparent;
    padding-bottom: 4px;
  }

  .nav-link:hover {
    color: #42A5F5;
    border-bottom: 2px solid #42A5F5;
  }

  .social-icon {
    color: #ffffff;
    text-decoration: none;
    text-shadow: 0 0 1px rgba(255, 255, 255, 0.5);
    transition: color 0.3s;
    display: flex;
    align-items: center;
  }

  .social-icon:hover {
    color: #42A5F5;
  }
</style>
