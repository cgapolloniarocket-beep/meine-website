---
---

<header class="site-header">
  <div class="banner-stars">
    {Array.from({length: 20}).map((_, i) => (
      <div class="banner-star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 6}s; --size: ${Math.random() * 2 + 1}px; --brightness: 0.5;`} />
    ))}
    {Array.from({length: 8}).map((_, i) => (
      <div class="banner-star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 6}s; --size: ${Math.random() * 2 + 2}px; --brightness: 1;`} />
    ))}
  </div>
  <nav class="site-nav">
    <a href="/" class="brand">
      <img src="/apollonia_logo_white_black.png" alt="" class="logo" />
      <span class="brand-name">Apollonia Space</span>
    </a>
    <div class="nav-right">
      <a href="/" class="nav-link">Home</a>
      <a href="/podcast" class="nav-link">Podcast</a>
      <a href="/about" class="nav-link">About Us</a>

      <!-- YouTube -->
      <a href="#" target="_blank" title="YouTube" class="social-icon">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
      </a>

      <!-- Spotify -->
      <a href="#" target="_blank" title="Spotify" class="social-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.6-6-2-10-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.3-1 8.1-.6 11.1 1.2.4.2.5.7.3 1.1zm1.5-3.3c-.3.4-.8.5-1.2.3-3-1.9-7.7-2.4-11.3-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.1-1.3 9.2-.7 12.7 1.5.3.2.5.8.3 1.2zm.1-3.4c-3.7-2.2-9.7-2.4-13.2-1.3-.5.2-1.1-.1-1.3-.6-.2-.5.1-1.1.6-1.3 4-1.2 10.7-1 14.9 1.5.5.3.6.9.4 1.4-.3.5-.9.6-1.4.3z"/></svg>
      </a>

      <!-- Apple Podcasts -->
      <a href="#" target="_blank" title="Apple Podcasts" class="social-icon apple-fix">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M5.3 17.1c.2.5.4 1 .7 1.6.4.7.7 1.2 1 1.5.4.5.8.8 1.2.9.4.1.9.2 1.4.1.4-.1.8-.2 1.4-.5.5-.3 1-.4 1.5-.4s1 .1 1.5.4c.5.3 1 .4 1.4.5.5.1.9 0 1.3-.2.5-.3.9-.7 1.3-1.3.3-.4.6-.9.9-1.5.3-.7.6-1.4.7-2-.1 0-.5-.2-1.1-.5-.6-.3-1.1-.8-1.5-1.4-.4-.6-.7-1.4-.7-2.2 0-1 .3-1.8.9-2.5.3-.4.7-.7 1.2-1-0.7-1-1.7-1.5-2.9-1.6-.5 0-1.2.2-1.9.5-.7.3-1.1.5-1.3.5-.3 0-.7-.2-1.3-.5-.6-.3-1.1-.4-1.6-.5h-.3c-.8.1-1.6.4-2.3 1-.7.6-1.2 1.3-1.5 2.2-.4 1-.5 2.1-.4 3.2.1 1.1.4 2.3.9 3.4zM12 5.5c.3-1 .9-1.8 1.7-2.5.8-.7 1.7-1 2.6-1.1 0 1-.3 2-1 2.8-.7.9-1.6 1.4-2.7 1.5-.3 0-.5-.2-.6-.7z"/></svg>
      </a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    background: #000000;
    overflow: visible;
  }

  .site-header::after {
    content: '';
    position: absolute;
    bottom: -60px;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, #000000, transparent);
    pointer-events: none;
  }

  .banner-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .banner-star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: #ffffff;
    border-radius: 50%;
    opacity: 0;
    animation: starTwinkle 8s var(--delay) infinite ease-in-out;
  }

  @keyframes starTwinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: var(--brightness, 0.8); }
  }

  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 3rem 0.8rem 2rem;
    position: relative;
    z-index: 1;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #ffffff;
  }

 .logo {
  height: 60px;
  width: auto;
  display: block;
}

  .brand-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    font-weight: 400;
    font-style: normal;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-link {
    color: #ffffff;
    text-decoration: none;
    font-size: 1rem;
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-shadow: 0 0 1px rgba(255, 255, 255, 0.5);
    transition: color 0.3s, border-color 0.3s;
    border-bottom: 2px solid transparent;
    padding-bottom: 4px;
  }

  .nav-link:hover {
    color: #42A5F5;
    border-bottom: 2px solid #42A5F5;
  }

  .social-icon {
    color: #ffffff;
    text-decoration: none;
    text-shadow: 0 0 1px rgba(255, 255, 255, 0.5);
    transition: color 0.3s;
    display: flex;
    align-items: center;
    transform: translateY(-2px);
  }

  .social-icon:hover {
    color: #42A5F5;
  }

  .social-icon.apple-fix {
    margin-left: -4px;
    margin-right: -4px;
  }
</style>