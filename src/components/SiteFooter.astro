<style>
  .footer-line {
    width: 100%;
    height: 2px;
    background: linear-gradient(to right, #050d1a, #ffffff, #050d1a);
    display: block;
    position: relative;
    z-index: 10;
  }

  .site-footer {
    background: #000;
    color: #fff;
    padding: 5rem 4rem 3rem;
    font-family: 'Montserrat', sans-serif;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 6rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Newsletter */
  .newsletter h3 {
    font-family: 'Barlow', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .news-form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .news-form input {
    flex: 1;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    outline: none;
  }

  .news-form input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .news-form input:focus {
    border-color: #42A5F5;
  }

  .news-form button {
    background: #ffffff;
    color: #000;
    border: none;
    padding: 0.85rem 1.5rem;
    border-radius: 6px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.3s, color 0.3s;
    white-space: nowrap;
  }

  .news-form button:hover {
    background: #42A5F5;
    color: #ffffff;
  }

  .fineprint {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    line-height: 1.6;
  }

  .fineprint a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: underline;
  }

  .fineprint a:hover {
    color: #ffffff;
  }

  /* Columns */
  .fcol h5 {
    font-family: 'Barlow', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .fcol ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fcol ul li a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: color 0.3s;
  }

  .fcol ul li a:hover {
    color: #ffffff;
  }

  .social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Footer base */
  .footer-base {
    max-width: 1400px;
    margin: 2rem auto 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #ffffff;
  }

  .footer-logo {
    height: 40px;
    width: auto;
    display: block;
  }

  .footer-brand-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
    color: #ffffff;
  }

  small {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .site-footer {
      padding: 4rem 2rem 3rem;
    }

    .footer-base {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>