---
// Footer.astro — Contact + Newsletter + Footer
// Drop into src/components/ and import in your layout.
---

<section class="contact">
  <div class="contact-box">
    <div class="contact-glow" aria-hidden="true"></div>
    <div class="contact-content">
      <div class="contact-head">
        <h2 class="contact-title">Get in touch</h2>
      </div>

      <div class="contact-details">
        <div class="inquiry">
          <p class="inquiry-label">Media Inquiries</p>
          <a href="mailto:press@apolloniaspace.com">press@apolloniaspace.com</a>
        </div>
        <div class="inquiry-divider" aria-hidden="true"></div>
        <div class="inquiry">
          <p class="inquiry-label">General Inquiries</p>
          <a href="mailto:contact@apolloniaspace.com">contact@apolloniaspace.com</a>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="footer-line"></div>

<footer class="site-footer">
