    </div>

  </div>

  <div class="footer-base">
    <a class="brand" href="/">
      <img src="/apollonia_logo_white_black.png" alt="Apollonia Space" class="footer-logo" />
      <span class="footer-brand-name">Apollonia Space</span>
    </a>
    <small>© 2026 Apollonia Space. All rights reserved.</small>
  </div>
</footer>

<script>
  (function () {
    'use strict';

    const el = {
      email: document.getElementById('news-email'),
      hp:    document.getElementById('news-hp'),
      btn:   document.getElementById('news-submit'),
      status:document.getElementById('news-status'),
    };

    if (!el.email || !el.btn || !el.status) return;

    let lastSubmitTime = 0;
    const COOLDOWN_MS = 3000;
    const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

    function setStatus(msg, isError) {
      el.status.textContent = msg;
      el.status.style.color = isError ? '#ef4444' : '#42A5F5';
    }

    function clearStatus() {
      el.status.textContent = '';
    }

    async function subscribe() {
      clearStatus();

      const now = Date.now();
      if (now - lastSubmitTime < COOLDOWN_MS) {
        setStatus('One moment\u2026', true);
        return;
      }

      const email = el.email.value.trim().toLowerCase();

      if (!email) {
        setStatus('Please enter your email address.', true);
        return;
      }
      if (email.length > 254 || !EMAIL_RE.test(email)) {
        setStatus('Please enter a valid email address.', true);
        return;
      }

      lastSubmitTime = now;
      el.btn.disabled = true;
      el.btn.textContent = 'Subscribing\u2026';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: email,
            website: el.hp ? el.hp.value : '',
          }),
        });

        if (res.ok) {
          setStatus('Thanks \u2014 you\u2019re subscribed.', false);
          el.email.value = '';
        } else if (res.status === 429) {
          setStatus('Too many attempts. Please wait a moment.', true);
        } else {
          setStatus('Something went wrong. Please try again.', true);
        }
      } catch {
        setStatus('Network error. Please try again.', true);
      } finally {
        el.btn.disabled = false;
        el.btn.textContent = 'Subscribe';
      }
    }

    el.btn.addEventListener('click', subscribe);
    el.email.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        subscribe();
      }
    });
  })();
</script>

<style>
  /* ─── Get in touch ─── */
  .contact {
    background: #000;
    padding: clamp(3rem, 6vw, 5rem) 2rem clamp(3rem, 6vw, 4rem);
  }

  .contact-box {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 20px;
    background:
      radial-gradient(120% 120% at 12% 50%, rgba(66, 165, 245, 0.10) 0%, rgba(66, 165, 245, 0) 55%),
      rgba(255, 255, 255, 0.02);
    overflow: hidden;
  }

  .contact-content {
    position: relative;
    z-index: 1;
    padding: clamp(2.5rem, 5vw, 4rem) clamp(2rem, 5vw, 4.5rem);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }

  .contact-head {
    padding-top: 0;
  }

  .contact-title {
    font-family: 'Barlow', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0;
    text-transform: uppercase;
  }

  .contact-details {
    display: flex;
    align-items: center;
    gap: clamp(2.5rem, 5vw, 4rem);
    flex-wrap: nowrap;
    justify-content: flex-end;
    padding-top: 2px;
  }

  .inquiry {
    display: flex;
    flex-direction: column;
  }

  .inquiry-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 0.25rem;
  }

  .inquiry a {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    font-weight: 500;
    color: #ffffff;
    text-decoration: none;
    border-bottom: none;
    padding-bottom: 6px;
    transition: color 0.25s ease;
    white-space: nowrap;
  }

  .inquiry a:hover {
    color: #42A5F5;
  }

  .inquiry-divider {
    width: 1px;
    align-self: stretch;
    min-height: 70px;
    background: rgba(255, 255, 255, 0.16);
  }

  @media (max-width: 1200px) {
    .contact-details {
      justify-content: flex-start;
    }
  }

  @media (max-width: 1024px) {
    .contact-content {
      grid-template-columns: 1fr;
      gap: 3rem;
      align-items: start;
    }
    .contact-details {
      padding-top: 0;
    }
  }

  @media (max-width: 680px) {
    .contact {
      padding: 2.5rem 1rem 2.5rem;
    }

    .contact-box {
      border-radius: 14px;
    }

    .contact-details {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }

    .inquiry-divider {
      display: none;
    }

    .inquiry a {
      white-space: normal;
      word-break: break-all;
    }
  }

  /* ─── Footer line ─── */
  .footer-line {
    width: 100%;
    height: 2px;
    background: linear-gradient(to right, #050d1a, #ffffff, #050d1a);
    display: block;
    position: relative;
    z-index: 10;
  }

  /* ─── Footer ─── */
  .site-footer {
    background: #000;
    color: #fff;
    padding: 3.5rem 4rem 3rem;
    font-family: 'Barlow', sans-serif;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 6rem;
    align-items: start;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* ─── Newsletter ─── */
  .newsletter h3 {
    font-family: 'Barlow', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .news-form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .news-form input[type="email"] {
    flex: 1;
    min-width: 0;
    padding: 0.85rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.25s ease;
  }

  .news-form input[type="email"]::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .news-form input[type="email"]:focus {
    border-color: #42A5F5;
  }

  .news-hp {
    position: absolute;
    left: -9999px;
    width: 0;
    height: 0;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .news-form button {
    background: #ffffff;
    color: #000;
    border: none;
    padding: 0.85rem 1.5rem;
    border-radius: 6px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.3s, color 0.3s, opacity 0.3s;
    white-space: nowrap;
  }

  .news-form button:hover {
    background: #42A5F5;
    color: #ffffff;
  }

  .news-form button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .news-status {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    color: #42A5F5;
    min-height: 1.4em;
    margin: 0.5rem 0 0.75rem;
    transition: color 0.25s ease;
  }

  .fineprint {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    line-height: 1.6;
  }

  .fineprint a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: underline;
  }

  .fineprint a:hover {
    color: #ffffff;
  }

  /* ─── Footer columns ─── */
  .fcol h5 {
    font-family: 'Barlow', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.1em;
    margin-top: 0;
    margin-bottom: 1.5rem;
  }

  .fcol ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fcol ul li a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: color 0.3s;
  }

  .fcol ul li a:hover {
    color: #ffffff;
  }

  .social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* ─── Footer base ─── */
  .footer-base {
    max-width: 1400px;
    margin: 2rem auto 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #ffffff;
  }

  .footer-logo {
    height: 40px;
    width: auto;
    display: block;
  }

  .footer-brand-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
    color: #ffffff;
  }

  small {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (min-width: 1025px) {
    .footer-inner > :nth-child(2) {
      padding-left: 5rem;
    }
  }

  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 3rem 2rem;
    }

    .newsletter {
      grid-column: 1 / -1;
    }

    .site-footer {
      padding: 4rem 2rem 3rem;
    }

    .footer-base {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }

  @media (max-width: 600px) {
    .site-footer {
      padding: 3rem 1.5rem 2.5rem;
    }

    .footer-inner {
      gap: 2.5rem 1rem;
    }

    .newsletter h3 {
      font-size: 1rem;
      line-height: 1.2;
    }

    .lead {
      font-size: 0.95rem;
    }

    .news-form {
      flex-direction: column;
      gap: 0.75rem;
    }

    .news-form button {
      width: 100%;
      padding: 0.9rem 1.5rem;
    }

    .fcol h5 {
      font-size: 1rem;
    }

    .fcol ul li a {
      font-size: 0.9rem;
    }

    .social {
      gap: 0.5rem;
    }

    .footer-base {
      margin-top: 1.5rem;
    }
  }
</style>