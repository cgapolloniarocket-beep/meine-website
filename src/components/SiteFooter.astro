    <div class="newsletter">
      <h3>Join the Apollonia Space community</h3>
      <p class="lead">New episodes, space industry briefings and behind-the-scenes notes. Straight to your inbox.</p>

      <div class="news-form" role="form" aria-label="Newsletter signup">
        <input
          type="email"
          id="news-email"
          placeholder="Type your email…"
          aria-label="Email address"
          autocomplete="email"
          maxlength="254"
          required
        />
        <input
          type="text"
          id="news-hp"
          name="website"
          autocomplete="off"
          tabindex="-1"
          aria-hidden="true"
          class="news-hp"
        />
        <button id="news-submit" type="button">Subscribe</button>
      </div>

      <p class="news-status" id="news-status" role="status" aria-live="polite"></p>

      <p class="fineprint">
        By subscribing you agree to Substack's
        <a href="https://substack.com/tos" target="_blank" rel="noopener">Terms of Use</a>,
        <a href="https://substack.com/privacy" target="_blank" rel="noopener">Privacy Policy</a> and
        <a href="https://substack.com/ccpa#personal-data-collected" target="_blank" rel="noopener">Information collection notice</a>.
      </p>
    </div>

    <div class="fcol">
      <h5>EXPLORE</h5>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/podcast">Podcast</a></li>
        <li><a href="/pressnews">Press & News</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/imprint">Imprint</a></li>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/faq">FAQ</a></li>
