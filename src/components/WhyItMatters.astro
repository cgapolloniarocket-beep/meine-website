---
// WhyItMatters.astro — single column, narrow measure (max 720px).
---

<section id="why" class="why">
  <div class="container">
    <div class="why__measure">
      <p class="eyebrow">Why it matters</p>
      <div class="why__body">
        <p>[PLACEHOLDER_PROBLEM_STATEMENT — paragraph 1]</p>
        <p>[PLACEHOLDER_PROBLEM_STATEMENT — paragraph 2]</p>
      </div>
    </div>
  </div>
</section>

<style>
  .why {
    border-top: 1px solid var(--rule);
    padding-block: clamp(72px, 12vw, 140px);
  }

  .why__measure {
    max-width: 720px;
  }

  .why__body {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 1.25em;
    font-size: clamp(1.125rem, 1.8vw, 1.375rem);
    line-height: 1.55;
    color: var(--fg);
  }
</style>
