---
// Footer.astro — three columns on desktop, stacked on mobile. Hairline top rule.
---

<footer id="contact" class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__brandlink" aria-label="Apollonia Space — home">
        <svg class="footer__spike" viewBox="0 0 128 128" fill="none" aria-hidden="true" focusable="false">
          <path d="M50.4 78.5a75.1 75.1 0 0 0-28.5 6.9l24.2-65.7c.7-2 1.9-3.2 3.4-3.2h29c1.5 0 2.7 1.2 3.4 3.2l24.2 65.7s-11.6-7-28.5-7L67 45.5c-.4-1.7-1.6-2.8-2.9-2.8-1.3 0-2.5 1.1-2.9 2.7L50.4 78.5Zm-1.1 28.2Zm-4.2-20.2c-2 6.6-.6 15.8 4.2 20.2a17.5 17.5 0 0 1 .2-.7 5.5 5.5 0 0 1 5.7-4.5c2.8.1 4.3 1.5 4.7 4.7.2 1.1.2 2.3.2 3.5v.4c0 2.7.7 5.2 2.2 7.4a13 13 0 0 0 5.7 4.9v-.3l-.2-.3c-1.8-5.6-.5-9.5 4.4-12.8l1.5-1a73 73 0 0 0 3.2-2.2 16 16 0 0 0 6.8-11.4c.3-2 .1-4-.6-6l-.8.6-1.6 1a37 37 0 0 1-22.4 2.7c-5-.7-9.7-2-13.2-6.2Z" />
        </svg>
        <span class="footer__wordmark">APOLLONIA</span>
      </a>
      <p class="footer__copy">© 2026 [PLACEHOLDER_LEGAL_ENTITY — verify "Apollonia Space Ltd" or correct entity]</p>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      <ul>
        <li><a href="#technology">Technology</a></li>
        <li><a href="#team">Team</a></li>
        <li><a href="#news">News</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>

    <div class="footer__contact">
      <a href="mailto:cg@apolloniaspace.com">cg@apolloniaspace.com</a>
      <a href="[PLACEHOLDER_LINKEDIN_URL]" target="_blank" rel="noopener">LinkedIn</a>
      <a href="[PLACEHOLDER_X_URL]" target="_blank" rel="noopener">X</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--rule);
    padding-block: clamp(48px, 7vw, 80px);
  }

  .footer__inner {
    display: grid;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 48px;
    }
  }

  .footer__brandlink {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--fg);
  }
  .footer__spike {
    width: 24px;
    height: 24px;
  }
  .footer__spike path {
    fill: var(--fg);
  }
  .footer__wordmark {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: 0.18em;
  }

  .footer__copy {
    margin-top: 18px;
    font-size: 0.8125rem;
    color: var(--fg-dim);
    max-width: 32ch;
  }

  .footer__nav ul,
  .footer__contact {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__nav a,
  .footer__contact a {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--fg-muted);
    text-decoration: none;
    width: fit-content;
    transition: color 160ms ease-out;
  }
  .footer__nav a:hover,
  .footer__contact a:hover {
    color: var(--fg);
  }
</style>
