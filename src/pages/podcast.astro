---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout title="Apollonia – Podcast">

  <section class="page-one">
    <div class="stars">
      {Array.from({length: 30}).map((_, i) => (
        <div class="star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 4}s; --size: ${Math.random() * 2 + 1}px;`} />
      ))}
      {Array.from({length: 8}).map((_, i) => (
        <div class="star bright" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 4}s; --size: ${Math.random() * 3 + 2}px;`} />
      ))}
    </div>

    <div class="shooting-stars">
      <div class="shooting-star"></div>
      <div class="shooting-star"></div>
      <div class="shooting-star"></div>
    </div>

    <SiteHeader />

    <div class="hero-text">
      <h1>
        PODCASTS<br />
        FOR THE<br />
        SPACE INDUSTRY<br />
        OF TOMORROW
      </h1>
      <p class="subtitle">Unfiltered conversations with the leaders driving the new space economy.</p>
      <p class="subtitle">Founders, Investors, Politicians, Operators and everyone in between.</p>
    </div>

    <div class="featured-episode">
      <a href="https://youtube.com" target="_blank" class="ep-image-link">
        <div class="ep-image"></div>
      </a>
      <div class="ep-content">
        <span class="featured-label">FEATURED EPISODE</span>
        <h3>EPISODE TITLE HERE | GUEST NAME AND KEY TOPICS</h3>
        <a href="#" class="view-ep">View Episode</a>
        <div class="ep-platforms">
          <a href="#" class="platform-link">YouTube</a>
          <a href="#" class="platform-link">Spotify</a>
          <a href="#" class="platform-link">Apple</a>
          <a href="#" class="platform-link">Substack</a>
        </div>
      </div>
    </div>
  </section>

  <section class="page-two" id="episodes">
    <div class="sec-head">
      <h2>Recent Episodes</h2>
    </div>

    <div class="ep-grid">
      <article class="ep-card">
        <div class="ep-thumb"></div>
        <div class="ep-card-body">
          <div class="meta">48 min · Policy</div>
          <h4>Who Actually Owns the Moon?</h4>
          <div class="who">X X — Space Law</div>
        </div>
      </article>

      <article class="ep-card">
        <div class="ep-thumb"></div>
        <div class="ep-card-body">
          <div class="meta">61 min · Founders</div>
          <h4>Building a Satellite Startup From Zero</h4>
          <div class="who">X X — Founder, Company </div>
        </div>
      </article>

      <article class="ep-card">
        <div class="ep-thumb"></div>
        <div class="ep-card-body">
          <div class="meta">39 min · Capital</div>
          <h4>How VCs Underwrite Deep-Tech Risk</h4>
          <div class="who">X X — Partner, Venture Capital</div>
        </div>
      </article>
    </div>
  </section>

</Layout>

<style>
  .page-one {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background-color: #050d1a;
  }

  .stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: #ffffff;
    border-radius: 50%;
    opacity: 0;
    animation: twinkle 3s var(--delay) infinite ease-in-out;
  }

  .star.bright {
    box-shadow: 0 0 10px 4px rgba(255, 255, 255, 0.8);
    animation: twinkleBright 6s var(--delay) infinite ease-in-out;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.8; }
  }

  @keyframes twinkleBright {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }

  .shooting-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 5;
  }

  .shooting-star {
    position: absolute;
    width: 200px;
    height: 3px;
    background: linear-gradient(to right, #ffffff, transparent);
    border-radius: 50%;
    opacity: 0;
    box-shadow: 0 0 12px 3px rgba(255, 255, 255, 0.5);
  }

  .shooting-star:nth-child(1) {
    top: 15%;
    left: 60%;
    transform: rotate(-35deg);
    animation: shoot 3s 2s infinite;
  }

  .shooting-star:nth-child(2) {
    top: 35%;
    left: 75%;
    transform: rotate(-30deg);
    animation: shoot 4s 5s infinite;
  }

  .shooting-star:nth-child(3) {
    top: 55%;
    left: 45%;
    transform: rotate(-40deg);
    animation: shoot 5s 8s infinite;
  }

  @keyframes shoot {
    0% { opacity: 0; transform: translateX(0) translateY(0) rotate(-35deg); }
    3% { opacity: 1; }
    15% { opacity: 0; transform: translateX(-400px) translateY(280px) rotate(-35deg); }
    100% { opacity: 0; }
  }

  .hero-text {
    padding: 10rem 4rem 0;
    position: relative;
    z-index: 3;
  }

h1 {
  font-family: 'Barlow', sans-serif;
  font-size: clamp(2rem, 5vw, 4rem);  /* kleiner als vorher */
  font-weight: 800;
  line-height: 0.95;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: -0.02em;
}

.subtitle {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.85rem;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.08em;
  margin-top: 0;
  text-transform: uppercase;
  padding-left: 0.5rem;
  line-height: 1.5;
  max-width: 45%;
}

.subtitle:first-of-type {
  margin-top: 1.5rem;
  margin-bottom: 0;
}
  .featured-episode {
    position: absolute;
    top: 10rem;
    bottom: 2rem;
    right: 4rem;
    left: 55%;
    z-index: 6;
    display: flex;
    flex-direction: column;
  }

  .ep-image-link {
    display: block;
    flex: 1;
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .ep-image {
    width: 100%;
    height: 90%;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s;
    cursor: pointer;
  }

  .ep-image:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .ep-content {
    display: flex;
    flex-direction: column;
  }

  .featured-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: #42A5F5;
    margin-bottom: 0.5rem;
  }

  .featured-episode h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    text-transform: uppercase;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .view-ep {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: #ffffff;
    text-decoration: none;
    margin-bottom: 0.5rem;
    transition: color 0.3s;
  }

  .view-ep:hover {
    color: #42A5F5;
  }

  .ep-platforms {
    display: flex;
    gap: 0.75rem;
  }

  .platform-link {
    font-family: 'Barlow', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: color 0.3s;
  }

  .platform-link:hover {
    color: #ffffff;
  }

  .page-two {
    min-height: 100vh;
    padding: 6rem 4rem;
    background: #050d1a;
  }

  .sec-head {
    margin-bottom: 3rem;
  }

  .sec-head h2 {
    font-family: 'Barlow', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .ep-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .ep-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s, background 0.3s;
    cursor: pointer;
  }

  .ep-card:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.35);
  }

  .ep-thumb {
    height: 180px;
    background: linear-gradient(135deg, #0a1628, #1a3a6e);
  }

  .ep-card-body {
    padding: 1.5rem;
  }

  .meta {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: #42A5F5;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .ep-card-body h4 {
    font-family: 'Barlow', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .who {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
  }

  @media (max-width: 768px) {
    .hero-text {
      padding: 7rem 2rem 0;
    }

    h1 {
      font-size: clamp(2.5rem, 12vw, 5rem);
    }

    .featured-episode {
      position: relative;
      top: auto;
      bottom: auto;
      right: auto;
      left: auto;
      margin: 2rem;
    }

    .ep-image {
      height: 200px;
    }

    .ep-grid {
      grid-template-columns: 1fr;
    }

    .page-two {
      padding: 4rem 2rem;
    }
  }
</style>
