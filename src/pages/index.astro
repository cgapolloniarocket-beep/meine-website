---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout title="Apollonia – Coming Soon">

  <section class="page-one">
    <div class="stars">
      {Array.from({length: 30}).map((_, i) => (
        <div class="star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 4}s; --size: ${Math.random() * 2 + 1}px;`} />
      ))}
      {Array.from({length: 8}).map((_, i) => (
        <div class="star bright" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 4}s; --size: ${Math.random() * 3 + 2}px;`} />
      ))}
    </div>

    <SiteHeader />

    <div class="hero-text">
      <h1>
        ENGINEERED<br />
        ON EARTH.<br />
        BUILT FOR SPACE.
      </h1>
    </div>

    <div class="globe-container" id="globe"></div>
  </section>

  <section class="page-two">
    <h2>Seite 2</h2>
  </section>

  <section class="page-three">
    <h2>Seite 3</h2>
  </section>

</Layout>

<script>
  import * as THREE from 'three';

  const container = document.getElementById('globe');
  
  if (container) {
    let width = container.clientWidth;
    let height = container.clientHeight;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
    camera.position.z = window.innerWidth < 768 ? 4.5 : 4.2;

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(width, height);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    const sunLight = new THREE.DirectionalLight(0xffffff, 3.2);
    sunLight.position.set(-6, 0.0, 0.0); 
    scene.add(sunLight);

    let earth: THREE.Mesh;
    let clouds: THREE.Mesh;
    let atmosphere: THREE.Mesh;
    let clock = new THREE.Clock();

    const textureLoader = new THREE.TextureLoader();
    
    textureLoader.load('/earth_texture.jpg', (earthTexture) => {
        const earthGeometry = new THREE.SphereGeometry(0.92, 96, 96);
        const earthMaterial = new THREE.MeshPhongMaterial({ map: earthTexture, shininess: 15, specular: new THREE.Color(0x111122) });
        earth = new THREE.Mesh(earthGeometry, earthMaterial);
        earth.rotation.x = 0.2;
        earth.renderOrder = 1;
        scene.add(earth);

        const cloudGeometry = new THREE.SphereGeometry(0.928, 96, 96);
        const cloudMaterial = new THREE.ShaderMaterial({
          vertexShader: `varying vec3 vNormal; varying vec3 vPosition; void main() { vNormal = normalize(normalMatrix * normal); vPosition = position; gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0); }`,
          fragmentShader: `varying vec3 vNormal; varying vec3 vPosition; uniform float uTime; float noise(vec3 p) { vec3 i = floor(p); vec3 f = fract(p); f = f*f*(3.0-2.0*f); float n = dot(i, vec3(1.0, 57.0, 113.0)); return mix(mix(mix(fract(sin(n)*43758.5453), fract(sin(n+1.0)*43758.5453), f.x), mix(fract(sin(n+57.0)*43758.5453), fract(sin(n+58.0)*43758.5453), f.x), f.y), mix(mix(fract(sin(n+113.0)*43758.5453), fract(sin(n+114.0)*43758.5453), f.x), mix(fract(sin(n+170.0)*43758.5453), fract(sin(n+171.0)*43758.5453), f.x), f.y), f.z); } float fbm(vec3 p) { float v = 0.0; float a = 0.5; for (int i = 0; i < 5; ++i) { v += a * noise(p); p *= 2.0; a *= 0.5; } return v; } void main() { vec3 coord = vPosition * 4.0 + vec3(uTime * 0.02, 0.0, 0.0); float d = smoothstep(0.52, 0.75, fbm(coord)); vec3 viewSunDir = normalize(viewMatrix * vec4(-6.0, 0.0, 0.0, 0.0)).xyz; float light = smoothstep(-0.2, 0.1, dot(vNormal, viewSunDir)); gl_FragColor = vec4(vec3(1.0), d * light * 0.7); }`,
          uniforms: { uTime: { value: 0.0 } },
          transparent: true, depthWrite: false
        });
        clouds = new THREE.Mesh(cloudGeometry, cloudMaterial);
        clouds.renderOrder = 2;
        scene.add(clouds);

        const atmosGeometry = new THREE.SphereGeometry(0.965, 96, 96);
        const atmosMaterial = new THREE.ShaderMaterial({
          vertexShader: `varying vec3 vViewNormal; void main() { vViewNormal = normalize(normalMatrix * normal); gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0); }`,
          fragmentShader: `varying vec3 vViewNormal; uniform float uTime; void main() { float viewAngle = dot(vViewNormal, vec3(0.0, 0.0, 1.0)); float edgeGlow = clamp(pow(0.92 - viewAngle, 2.5), 0.0, 1.0); vec3 finalColor = mix(vec3(0.04, 0.15, 0.5), vec3(0.30, 0.55, 0.95), edgeGlow); float flicker = 1.0 + (sin(uTime * 4.0) * 0.025) + (sin(uTime * 1.0) * 0.015); float intensity = edgeGlow * 1.5 * flicker; gl_FragColor = vec4(finalColor * intensity, intensity * 0.80); }`,
          uniforms: { uTime: { value: 0.0 } },
          blending: THREE.AdditiveBlending, side: THREE.BackSide, transparent: true, depthWrite: false
        });
        atmosphere = new THREE.Mesh(atmosGeometry, atmosMaterial);
        atmosphere.renderOrder = 3;
        scene.add(atmosphere);

        animate();
    });

    function animate() {
      requestAnimationFrame(animate);
      const t = clock.getElapsedTime();
      if (earth) earth.rotation.y += 0.0003;
      if (clouds) { clouds.rotation.y += 0.00045; (clouds.material as THREE.ShaderMaterial).uniforms.uTime.value = t; }
      if (atmosphere) { atmosphere.rotation.y += 0.0003; (atmosphere.material as THREE.ShaderMaterial).uniforms.uTime.value = t; }
      renderer.render(scene, camera);
    }

    window.addEventListener('resize', () => {
      width = container.clientWidth; height = container.clientHeight;
      camera.aspect = width / height; camera.updateProjectionMatrix();
      camera.position.z = window.innerWidth < 768 ? 4.5 : 4.2;
      renderer.setSize(width, height);
    });
  }
</script>

<style>
  .page-one { 
    position: relative; 
    height: 100vh; 
    overflow: hidden; 
    background-color: #02050a; /* Basis-Dunkelheit */
  }

  /* Abdunklungs-Overlay für Page One */
  .page-one::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 10, 0.3); /* Hier den Wert 0.3 anpassen für mehr/weniger Dunkelheit */
    z-index: 2;
    pointer-events: none;
  }

  .stars { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .star { position: absolute; left: var(--x); top: var(--y); width: var(--size); height: var(--size); background: #fff; border-radius: 50%; opacity: 0; animation: twinkle 3s var(--delay) infinite ease-in-out; }
  .star.bright { box-shadow: 0 0 10px 4px rgba(255, 255, 255, 0.8); animation: twinkleBright 6s var(--delay) infinite ease-in-out; }
  @keyframes twinkle { 0%, 100% { opacity: 0; } 50% { opacity: 0.8; } }
  @keyframes twinkleBright { 0%, 100% { opacity: 0; } 50% { opacity: 1; } }

  .hero-text { position: relative; z-index: 3; pointer-events: none; padding: 10rem 4rem 0; }
  h1 { font-size: clamp(2rem, 6vw, 5rem); line-height: 0.95; color: #e0e0e0; letter-spacing: -0.02em; }

  .globe-container {
    position: absolute;
    top: 50%;
    right: 0;
    width: 950px;
    height: 950px;
    z-index: 1; /* Unter dem Overlay, damit der Globe auch leicht gedimmt wird */
    pointer-events: none;
    transform: translate(32%, -45%);
  }

  .page-two, .page-three { min-height: 100vh; padding: 4rem; background: var(--navy-deep); }
  .page-two h2, .page-three h2 { font-size: 1.5rem; font-weight: 400; color: #000; letter-spacing: 0.1em; }

  @media (max-width: 768px) {
    .hero-text { padding: 7rem 2rem 0; }
    h1 { font-size: clamp(2.5rem, 12vw, 5rem); }
    .globe-container { width: 440px; height: 440px; right: 0; top: auto; bottom: 0; transform: translate(25%, 12%); }
  }
</style>