---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout title="Apollonia – Coming Soon">
  <section class="page-one">
    <SiteHeader transition:persist />

    <div class="hero-text">
      <h1>
        ENGINEERED
        <br />
        ON EARTH.
        <br />
        BUILT FOR SPACE.
      </h1>
    </div>

    <div class="globe-container" id="globe" transition:persist></div>
  </section>
</Layout>

<script>
  type GlobeState = {
    rafId: number | null;
    g: any | null;
    clouds: any | null;
    stars: any | null;
    renderer: any | null;
    scene: any | null;
    camera: any | null;
  };

  const w = window as any;
  const state: GlobeState = (w.__globeState ||= {
    rafId: null,
    g: null,
    clouds: null,
    stars: null,
    renderer: null,
    scene: null,
    camera: null,
  });

  // Zeit-Variable für die Blinzel-Animation
  let clockTime = 0;

  function startAnimation() {
    if (state.rafId !== null) return;
    const tick = () => {
      state.rafId = requestAnimationFrame(tick);
      
      // Rotationen
      if (state.g) state.g.rotation.y += 0.0004;
      if (state.clouds) state.clouds.rotation.y += 0.0003;
      if (state.stars) {
        state.stars.rotation.y += 0.00002; // Sehr langsame Rotation
        
        // NEU: Sanftes, langsames Blinzeln über Sinus-Welle steuern
        clockTime += 0.005; // Je kleiner der Wert, desto langsamer das Blinzeln
        // Pendelt die Opacity sanft zwischen 0.2 und 0.5 hin und her
        state.stars.material.opacity = 0.35 + Math.sin(clockTime) * 0.15;
      }
      
      if (state.renderer && state.scene && state.camera) {
        state.renderer.render(state.scene, state.camera);
      }
    };
    tick();
  }

  function stopAnimation() {
    if (state.rafId !== null) {
      cancelAnimationFrame(state.rafId);
      state.rafId = null;
    }
  }

  async function initGlobe() {
    const container = document.getElementById('globe');
    if (!container) return;

    if (container.dataset.initialized === 'true') {
      startAnimation();
      return;
    }
    container.dataset.initialized = 'true';
    container.style.opacity = '0';

    const THREE = await import('three');

    const R = 0.92;
    state.renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    state.renderer.setSize(container.clientWidth, container.clientHeight);
    
    state.renderer.outputColorSpace = THREE.SRGBColorSpace;
    state.renderer.toneMapping = THREE.ACESFilmicToneMapping; 
    state.renderer.toneMappingExposure = 1.4; 
    container.appendChild(state.renderer.domElement);

    state.scene = new THREE.Scene();
    state.camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
    state.camera.position.z = 4.8;

    const sunLight = new THREE.DirectionalLight(0xffffff, 3.0);
    sunLight.position.set(-1.8, 1.2, 3.2);
    state.scene.add(sunLight);

    const ambientLight = new THREE.AmbientLight(0x111111, 1.2);
    state.scene.add(ambientLight);

    // Sternenfeld Generierung
    const starsGeometry = new THREE.BufferGeometry();
    const starsCount = 1200; 
    const starPositions = new Float32Array(starsCount * 3);
    const starColors = new Float32Array(starsCount * 3); 

    for (let i = 0; i < starsCount * 3; i += 3) {
      const radius = 25 + Math.random() * 20; 
      const u = Math.random();
      const v = Math.random();
      const theta = u * 2.0 * Math.PI;
      const phi = Math.acos(2.0 * v - 1.0);
      
      starPositions[i] = radius * Math.sin(phi) * Math.cos(theta);
      starPositions[i + 1] = radius * Math.sin(phi) * Math.sin(theta);
      starPositions[i + 2] = radius * Math.cos(phi);

      const brightness = 0.5 + Math.random() * 0.5; 
      starColors[i] = brightness;       
      starColors[i + 1] = brightness * 0.95; 
      starColors[i + 2] = brightness * 1.0;  
    }

    starsGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
    starsGeometry.setAttribute('color', new THREE.BufferAttribute(starColors, 3));

    const starsMaterial = new THREE.PointsMaterial({
      size: 0.012,             
      sizeAttenuation: true,
      vertexColors: true,      
      transparent: true,
      opacity: 0.4, // Start-Wert, wird im Loop animiert
      blending: THREE.AdditiveBlending
    });

    state.stars = new THREE.Points(starsGeometry, starsMaterial);
    state.scene.add(state.stars);

    state.g = new THREE.Group();
    state.g.rotation.x = 0.12;
    state.g.rotation.y = 3.6; 
    state.scene.add(state.g);

    const manager = new THREE.LoadingManager();
    const loader = new THREE.TextureLoader(manager);

    const textureMap = loader.load('/assets/earth_atmos_2048.jpg');
    const textureSpecular = loader.load('/assets/earth_specular_2048.jpg');
    const textureNormal = loader.load('/assets/earth_normal_2048.jpg');
    const cloudTexture = loader.load('/assets/earth_clouds_2048.png');

    textureMap.colorSpace = THREE.SRGBColorSpace;

    const earthMat = new THREE.MeshPhongMaterial({
      map: textureMap,
      specularMap: textureSpecular,
      normalMap: textureNormal,
      normalScale: new THREE.Vector2(0.9, 0.9),
      shininess: 100,                        
      specular: new THREE.Color(0x333333)    // Seidenmatter Glanz
    });

    const earth = new THREE.Mesh(new THREE.SphereGeometry(R, 96, 96), earthMat);
    state.g.add(earth);

    state.clouds = new THREE.Mesh(
      new THREE.SphereGeometry(R + 0.006, 96, 96),
      new THREE.MeshPhongMaterial({
        map: cloudTexture,
        transparent: true,
        opacity: 0.75,
        depthWrite: false,
        blending: THREE.AdditiveBlending 
      })
    );
    state.g.add(state.clouds);

    manager.onLoad = () => {
      earthMat.needsUpdate = true;
      if (state.clouds) (state.clouds.material as any).needsUpdate = true;
      
      container.style.transition = 'opacity 1.8s ease-out';
      container.style.opacity = '1';
      startAnimation();
    };
  }

  document.addEventListener('astro:page-load', () => {
    if (window.location.pathname === '/') {
      initGlobe();
    } else {
      stopAnimation();
    }
  });

  document.addEventListener('astro:before-swap', () => {
    if (window.location.pathname === '/') {
      stopAnimation();
    }
  });
</script>

<style>
  .page-one {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background-color: #000000; 
  }

  .hero-text {
    position: relative;
    z-index: 3;
    pointer-events: none;
    padding: 10rem 4rem 0;
  }

  h1 {
    font-family: 'Barlow', sans-serif;
    font-size: clamp(2rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 0.95;
    color: #e0e0e0;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0;
  }

  .globe-container {
    position: absolute;
    top: 50%;
    left: 80%;
    width: 950px;
    height: 950px;
    z-index: 2;
    pointer-events: none;
    transform: translate(-50%, -45%);
  }

  @media (max-width: 768px) {
    .hero-text {
      padding: 8.5rem 1.5rem 0 2.5rem;
      max-width: 58%;
    }

    h1 {
      font-size: 1.9rem;
      line-height: 1.1;
    }

    .globe-container {
      left: 78%;
      top: 28%;
      width: 320px;
      height: 320px;
      transform: translate(-50%, -50%);
      opacity: 0.9;
    }
  }

  @media (max-width: 380px) {
    .hero-text {
      padding: 6.5rem 1.2rem 0;
      max-width: 60%;
    }

    h1 {
      font-size: 1.6rem;
    }

    .globe-container {
      left: 80%;
      top: 25%;
      width: 260px;
      height: 260px;
    }
  }
</style>