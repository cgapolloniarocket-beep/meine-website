---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout title="Apollonia – Coming Soon">

  <div class="stars">
    {Array.from({length: 60}).map((_, i) => (
      <div class="star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 4}s; --size: ${Math.random() * 2 + 1}px;`} />
    ))}
  </div>

<SiteHeader />

  <main id="main-content">
    <p class="tagline">Something new is on the way.</p>
  </main>

</Layout>

<style>
  .stars {
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: var(--cream);
    border-radius: 50%;
    opacity: 0;
    animation: twinkle 4s var(--delay) infinite ease-in-out;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.6; }
  }

  main {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 2rem;
    text-align: center;
    position: relative;
  }

  .tagline {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-style: italic;
    color: var(--cream-pale);
    font-weight: 400;
  }

  .email {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(196, 164, 110, 0.3);
    padding-bottom: 2px;
    transition: border-color 0.3s;
  }

  .email:hover {
    border-color: var(--accent);
  }
</style>
