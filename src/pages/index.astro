---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---
 
<Layout title="Apollonia – Coming Soon">
  <section class="page-one">
    <div class="stars">
      {Array.from({ length: 120 }).map(() => {
        const size = (0.5 + Math.random() * 1.5).toFixed(2);
        const opacity = (0.2 + Math.random() * 0.5).toFixed(2);
        return (
          <div class="star" style={`
            --x: ${Math.random() * 100}%; 
            --y: ${Math.random() * 100}%; 
            --size: ${size}px; 
            --opacity: ${opacity};
            --dur: ${3 + Math.random() * 4}s;
          `} />
        );
      })}
    </div>
 
    <SiteHeader transition:persist />
 
    <div class="hero-text">
      <h1>
        ENGINEERED
        <br />
        ON EARTH.
        <br />
        BUILT FOR SPACE.
      </h1>
    </div>
 
    <div class="globe-container" id="globe" transition:persist></div>
  </section>
</Layout>
 
<script>
  import * as THREE from 'three';
 
  function initGlobe() {
    const container = document.getElementById('globe');
    if (!container) return;
 
    // Skip if already initialized (because of transition:persist)
    if (container.dataset.initialized === 'true') return;
    container.dataset.initialized = 'true';
 
    container.style.opacity = '0';
 
    const R = 0.92;
    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(container.clientWidth, container.clientHeight);
    container.appendChild(renderer.domElement);
 
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
    camera.position.z = 4.8;
 
    const sunLight = new THREE.DirectionalLight(0xfff4e6, 2.0);
    sunLight.position.set(-2, 0.5, 3);
    scene.add(sunLight);
 
    const g = new THREE.Group();
    g.rotation.x = 0.1;
    g.rotation.y = 4.0;
    scene.add(g);
 
    const manager = new THREE.LoadingManager();
    const loader = new THREE.TextureLoader(manager);
 
    const earthMat = new THREE.MeshPhongMaterial({
      map: loader.load('https://cdn.jsdelivr.net/gh/mrdoob/three.js@r128/examples/textures/planets/earth_atmos_2048.jpg'),
      specularMap: loader.load('https://cdn.jsdelivr.net/gh/mrdoob/three.js@r128/examples/textures/planets/earth_specular_2048.jpg'),
      normalMap: loader.load('https://cdn.jsdelivr.net/gh/mrdoob/three.js@r128/examples/textures/planets/earth_normal_2048.jpg'),
      shininess: 10,
    });
 
    const earth = new THREE.Mesh(new THREE.SphereGeometry(R, 96, 96), earthMat);
    g.add(earth);
 
    const clouds = new THREE.Mesh(
      new THREE.SphereGeometry(R + 0.005, 96, 96),
      new THREE.MeshPhongMaterial({
        map: loader.load('https://cdn.jsdelivr.net/gh/mrdoob/three.js@r128/examples/textures/planets/earth_clouds_2048.png'),
        transparent: true,
        opacity: 0.7,
        depthWrite: false,
      })
    );
    g.add(clouds);
 
    manager.onLoad = () => {
      container.style.transition = 'opacity 2.5s';
      container.style.opacity = '1';
 
      function animate() {
        requestAnimationFrame(animate);
        g.rotation.y += 0.0004;
        clouds.rotation.y += 0.0003;
        renderer.render(scene, camera);
      }
      animate();
    };
  }
 
  // Run on first load + after every ViewTransition
  document.addEventListener('astro:page-load', initGlobe);
</script>
 
<style>
  .page-one {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background-color: #050d1a; /* angeglichen an podcast/about */
  }
 
  .stars { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .star { position: absolute; left: var(--x); top: var(--y); width: var(--size); height: var(--size); background: white; border-radius: 50%; opacity: var(--opacity); animation: twinkle var(--dur) infinite alternate; }
  @keyframes twinkle { from { opacity: 0.2; } to { opacity: 1; } }
 
  .hero-text {
    position: relative;
    z-index: 3;
    pointer-events: none;
    padding: 10rem 4rem 0;
  }
 
  h1 {
    font-family: 'Barlow', sans-serif;
    font-size: clamp(2rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 0.95;
    color: #e0e0e0;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0;
  }
 
  .globe-container {
    position: absolute;
    top: 50%;
    left: 80%;
    width: 950px;
    height: 950px;
    z-index: 2;
    pointer-events: none;
    transform: translate(-50%, -45%);
  }
 
  @media (max-width: 768px) {
    .hero-text {
      padding: 8.5rem 1.5rem 0 2.5rem;
      max-width: 58%;
    }
 
    h1 {
      font-size: 1.9rem;
      line-height: 1.1;
    }
 
    .globe-container {
      left: 78%;
      top: 28%;
      width: 320px;
      height: 320px;
      transform: translate(-50%, -50%);
      opacity: 0.9;
    }
  }
 
  @media (max-width: 380px) {
    .hero-text {
      padding: 6.5rem 1.2rem 0;
      max-width: 60%;
    }
 
    h1 {
      font-size: 1.6rem;
    }
 
    .globe-container {
      left: 80%;
      top: 25%;
      width: 260px;
      height: 260px;
    }
  }
</style>
 