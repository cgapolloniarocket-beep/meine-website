---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Apollonia – Podcasts & Space Tech">

  <!-- Navigation -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="#" class="nav-logo">
        <img src="/apollonia_lockup_navy.png" alt="Apollonia" />
      </a>
      <div class="nav-links">
        <a href="#about">About</a>
        <a href="#services">Services</a>
        <a href="#podcast">Podcast</a>
        <a href="#contact" class="nav-cta">Get in Touch</a>
      </div>
      <button class="nav-toggle" aria-label="Menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="#about">About</a>
    <a href="#services">Services</a>
    <a href="#podcast">Podcast</a>
    <a href="#contact">Get in Touch</a>
  </div>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <div class="star-field">
        {Array.from({length: 60}).map((_, i) => (
          <div class="star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 4}s; --size: ${Math.random() * 2 + 1}px;`} />
        ))}
      </div>
      <div class="hero-gradient"></div>
    </div>
    <div class="hero-content">
      <div class="hero-badge">Podcast Production × Space Tech</div>
      <h1 class="hero-title">
        Stories that
        <span class="hero-title-accent">launch</span>
        ideas into orbit
      </h1>
      <p class="hero-sub">
        We produce podcasts that build audiences and amplify bold visions.
        From narrative-driven series to founder interviews — we turn your story into reach.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Start Your Podcast</a>
        <a href="#services" class="btn btn-ghost">Explore Services</a>
      </div>
    </div>
    <div class="hero-scroll">
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- About -->
  <section class="about" id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-label">
          <span class="section-tag">About</span>
        </div>
        <div class="about-content">
          <h2 class="section-title">Built at the intersection of <em>storytelling</em> and <em>technology</em></h2>
          <p class="about-text">
            Apollonia is a podcast production studio with roots in the space technology industry.
            We understand what it takes to communicate complex, ambitious ideas to the world —
            because we're building in that space ourselves.
          </p>
          <p class="about-text">
            Our mission is simple: help founders, companies, and visionaries
            find their voice and grow their audience through world-class podcast production.
          </p>
        </div>
        <div class="about-stats">
          <div class="stat">
            <span class="stat-number">50+</span>
            <span class="stat-label">Episodes Produced</span>
          </div>
          <div class="stat">
            <span class="stat-number">10K+</span>
            <span class="stat-label">Monthly Listeners</span>
          </div>
          <div class="stat">
            <span class="stat-number">∞</span>
            <span class="stat-label">Ambition</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="services" id="services">
    <div class="container">
      <span class="section-tag">Services</span>
      <h2 class="section-title services-title">Everything you need to <em>launch</em> and <em>grow</em> your podcast</h2>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
          </div>
          <h3>Podcast Production</h3>
          <p>End-to-end production from concept development and recording to editing, mixing, and mastering. Studio-quality sound, every episode.</p>
        </div>

        <div class="service-card">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 20h9"/>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <h3>Content Strategy</h3>
          <p>We craft your narrative arc, plan your episode calendar, and develop topics that resonate with your target audience and drive growth.</p>
        </div>

        <div class="service-card">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
          </div>
          <h3>Distribution & Growth</h3>
          <p>Get your podcast on every platform. We handle distribution, SEO optimization, social clips, and audience growth strategies.</p>
        </div>

        <div class="service-card">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <polygon points="10 8 16 12 10 16 10 8"/>
            </svg>
          </div>
          <h3>Video Podcasting</h3>
          <p>Expand your reach with video. We produce visually compelling video episodes optimized for YouTube and social media platforms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Podcast Section -->
  <section class="podcast" id="podcast">
    <div class="container">
      <div class="podcast-grid">
        <div class="podcast-info">
          <span class="section-tag">Podcast</span>
          <h2 class="section-title">Listen to the <em>Apollonia Podcast</em></h2>
          <p class="about-text">
            Conversations with founders, engineers, and dreamers building the future.
            From space technology to startup culture — stories from the frontier.
          </p>
          <div class="podcast-links">
            <a href="#" class="btn btn-primary">Listen on Spotify</a>
            <a href="#" class="btn btn-ghost">Apple Podcasts</a>
          </div>
        </div>
        <div class="podcast-visual">
          <div class="podcast-card-stack">
            <div class="podcast-ep">
              <div class="ep-number">EP 12</div>
              <div class="ep-info">
                <h4>The Future of Satellite Communication</h4>
                <span>42 min</span>
              </div>
            </div>
            <div class="podcast-ep">
              <div class="ep-number">EP 11</div>
              <div class="ep-info">
                <h4>Building in Public: A Space Startup Story</h4>
                <span>38 min</span>
              </div>
            </div>
            <div class="podcast-ep">
              <div class="ep-number">EP 10</div>
              <div class="ep-info">
                <h4>From Garage to Launch Pad</h4>
                <span>55 min</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" id="contact">
    <div class="container">
      <div class="contact-inner">
        <span class="section-tag">Contact</span>
        <h2 class="contact-title">Ready to launch <em>your story</em>?</h2>
        <p class="contact-sub">Whether you're starting a podcast from scratch or want to level up your existing show — let's talk.</p>
        <a href="mailto:hello@apolloniaspace.com" class="contact-email">hello@apolloniaspace.com</a>
        <div class="contact-socials">
          <a href="#" aria-label="LinkedIn">LinkedIn</a>
          <span class="dot">·</span>
          <a href="#" aria-label="Twitter">Twitter</a>
          <span class="dot">·</span>
          <a href="#" aria-label="Instagram">Instagram</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <img src="/apollonia_mark_navy.png" alt="Apollonia" class="footer-logo" />
      <span>© 2026 Apollonia. All rights reserved.</span>
    </div>
  </footer>

</Layout>

<style>
  /* ========== NAV ========== */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 2rem;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background: rgba(6, 15, 31, 0.7);
    border-bottom: 1px solid rgba(232, 213, 183, 0.06);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo img {
    height: 28px;
    filter: brightness(0) invert(0.88) sepia(0.2) saturate(0.5) hue-rotate(10deg);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-links a {
    color: var(--text-light);
    text-decoration: none;
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    transition: color 0.3s;
  }

  .nav-links a:hover {
    color: var(--cream);
  }

  .nav-cta {
    background: rgba(232, 213, 183, 0.1);
    padding: 0.6rem 1.4rem !important;
    border-radius: 100px;
    border: 1px solid rgba(232, 213, 183, 0.15);
    color: var(--cream) !important;
    transition: all 0.3s !important;
  }

  .nav-cta:hover {
    background: rgba(232, 213, 183, 0.18) !important;
    border-color: rgba(232, 213, 183, 0.3) !important;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--cream);
    transition: 0.3s;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 65px;
    left: 0;
    right: 0;
    background: rgba(6, 15, 31, 0.95);
    backdrop-filter: blur(20px);
    padding: 2rem;
    flex-direction: column;
    gap: 1.5rem;
    z-index: 99;
    border-bottom: 1px solid rgba(232, 213, 183, 0.08);
  }

  .mobile-menu a {
    color: var(--cream);
    text-decoration: none;
    font-size: 1.1rem;
  }

  /* ========== HERO ========== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 2rem 4rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(30, 60, 114, 0.4), transparent),
      radial-gradient(ellipse 40% 30% at 70% 60%, rgba(196, 164, 110, 0.08), transparent);
  }

  .star-field {
    position: absolute;
    inset: 0;
  }

  .star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: var(--cream);
    border-radius: 50%;
    opacity: 0;
    animation: twinkle 4s var(--delay) infinite ease-in-out;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.7; }
  }

  .hero-content {
    position: relative;
    max-width: 800px;
    text-align: center;
    animation: fadeUp 1s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(196, 164, 110, 0.3);
    padding: 0.5rem 1.5rem;
    border-radius: 100px;
    margin-bottom: 2.5rem;
  }

  .hero-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 1.1;
    font-weight: 400;
    margin-bottom: 1.5rem;
    color: var(--cream-pale);
  }

  .hero-title-accent {
    font-style: italic;
    color: var(--accent);
  }

  .hero-sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-light);
    max-width: 560px;
    margin: 0 auto 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--cream), transparent);
    animation: scrollPulse 2s infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }

  /* ========== BUTTONS ========== */
  .btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    border-radius: 100px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: all 0.3s;
  }

  .btn-primary {
    background: var(--cream);
    color: var(--navy);
  }

  .btn-primary:hover {
    background: var(--cream-pale);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(232, 213, 183, 0.15);
  }

  .btn-ghost {
    color: var(--cream);
    border: 1px solid rgba(232, 213, 183, 0.25);
  }

  .btn-ghost:hover {
    border-color: rgba(232, 213, 183, 0.5);
    background: rgba(232, 213, 183, 0.05);
  }

  /* ========== SECTIONS SHARED ========== */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-tag {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--cream-pale);
    margin-bottom: 1.5rem;
  }

  .section-title em {
    font-style: italic;
    color: var(--accent);
  }

  /* ========== ABOUT ========== */
  .about {
    padding: 8rem 0;
    border-top: 1px solid rgba(232, 213, 183, 0.06);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
  }

  .about-content {
    max-width: 640px;
  }

  .about-text {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-light);
    margin-bottom: 1.25rem;
  }

  .about-stats {
    grid-column: 2;
    display: flex;
    gap: 4rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(232, 213, 183, 0.08);
  }

  .stat-number {
    font-family: 'Instrument Serif', serif;
    font-size: 2.5rem;
    color: var(--cream-pale);
    display: block;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-light);
    letter-spacing: 0.03em;
  }

  /* ========== SERVICES ========== */
  .services {
    padding: 8rem 0;
    background: linear-gradient(180deg, transparent, rgba(196, 164, 110, 0.03), transparent);
  }

  .services-title {
    max-width: 600px;
    margin-bottom: 4rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    padding: 2.5rem;
    border: 1px solid rgba(232, 213, 183, 0.08);
    border-radius: 16px;
    background: rgba(232, 213, 183, 0.02);
    transition: all 0.4s;
  }

  .service-card:hover {
    border-color: rgba(232, 213, 183, 0.15);
    background: rgba(232, 213, 183, 0.04);
    transform: translateY(-4px);
  }

  .service-icon {
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .service-card h3 {
    font-family: 'Instrument Serif', serif;
    font-size: 1.4rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
    color: var(--cream-pale);
  }

  .service-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-light);
  }

  /* ========== PODCAST ========== */
  .podcast {
    padding: 8rem 0;
    border-top: 1px solid rgba(232, 213, 183, 0.06);
  }

  .podcast-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .podcast-links {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .podcast-card-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .podcast-ep {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    border: 1px solid rgba(232, 213, 183, 0.08);
    border-radius: 12px;
    background: rgba(232, 213, 183, 0.02);
    transition: all 0.3s;
  }

  .podcast-ep:hover {
    border-color: rgba(232, 213, 183, 0.2);
    background: rgba(232, 213, 183, 0.05);
  }

  .ep-number {
    font-family: 'Instrument Serif', serif;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    background: rgba(196, 164, 110, 0.1);
    padding: 0.5rem 0.8rem;
    border-radius: 8px;
    white-space: nowrap;
  }

  .ep-info h4 {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--cream-pale);
    margin-bottom: 0.25rem;
  }

  .ep-info span {
    font-size: 0.8rem;
    color: var(--text-light);
  }

  /* ========== CONTACT ========== */
  .contact {
    padding: 10rem 0;
    text-align: center;
    background:
      radial-gradient(ellipse 50% 40% at 50% 60%, rgba(30, 60, 114, 0.3), transparent);
  }

  .contact-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 400;
    color: var(--cream-pale);
    margin-bottom: 1rem;
  }

  .contact-title em {
    font-style: italic;
    color: var(--accent);
  }

  .contact-sub {
    color: var(--text-light);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .contact-email {
    display: inline-block;
    font-family: 'Instrument Serif', serif;
    font-size: 1.5rem;
    color: var(--cream);
    text-decoration: none;
    border-bottom: 1px solid rgba(232, 213, 183, 0.3);
    padding-bottom: 4px;
    transition: all 0.3s;
  }

  .contact-email:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .contact-socials {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .contact-socials a {
    color: var(--text-light);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    transition: color 0.3s;
  }

  .contact-socials a:hover {
    color: var(--cream);
  }

  .dot {
    color: rgba(232, 213, 183, 0.2);
  }

  /* ========== FOOTER ========== */
  .footer {
    padding: 2rem 0;
    border-top: 1px solid rgba(232, 213, 183, 0.06);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    height: 24px;
    filter: brightness(0) invert(0.88) sepia(0.2) saturate(0.5) hue-rotate(10deg);
    opacity: 0.5;
  }

  .footer span {
    font-size: 0.8rem;
    color: var(--text-light);
    opacity: 0.5;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-toggle { display: flex; }

    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-stats {
      grid-column: 1;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .podcast-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 7rem 1.5rem 4rem;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const menu = document.getElementById('mobileMenu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.style.display === 'flex';
    if (menu) menu.style.display = isOpen ? 'none' : 'flex';
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (menu) menu.style.display = 'none';
    });
  });
</script>
