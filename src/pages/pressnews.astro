---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
 
// ─────────────────────────────────────────────────────────────────────────────
// EINTRÄGE PFLEGEN: Neue News einfach oben in dieses Array einfügen.
// category: 'Press Release' oder 'Newsletter'
// date:     ISO-Format YYYY-MM-DD
// url:      Link zum vollständigen Artikel (extern oder eigene Seite)
// ─────────────────────────────────────────────────────────────────────────────
 
type Category = 'Press Release' | 'Newsletter';
 
interface NewsItem {
  title: string;
  category: Category;
  date: string;
  excerpt: string;
  url: string;
}
 
const items: NewsItem[] = [
  {
    title: 'Apollonia Space announces spin-out from Imperial College London',
    category: 'Press Release',
    date: '2026-06-01',
    excerpt:
      "Apollonia Space, developing a novel Spherical Tokamak Thruster (STT) for in-space propulsion, has been formally established as a spin-out from Imperial College London's Plasma Propulsion Laboratory.",
    url: '#',
  },
  {
    title: 'Newsletter #01 — From the Plasma Lab',
    category: 'Newsletter',
    date: '2026-05-15',
    excerpt:
      "An introduction to our team, our technology, and what we're building. Subscribe to receive future updates directly to your inbox.",
    url: '#',
  },
  {
    title: 'Apollonia Space joins EIC Pathfinder application round',
    category: 'Press Release',
    date: '2026-04-20',
    excerpt:
      'The company has submitted its application to the European Innovation Council Pathfinder programme, targeting non-dilutive funding for early-stage development of its electrodeless plasma propulsion system.',
    url: '#',
  },
];
 
// Neueste zuerst
const sortedItems = [...items].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
 
const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
 
const slug = (c: Category) => c.toLowerCase().replace(' ', '-');
---
 
<SiteHeader />
 
<main class="press-news">
  <header class="page-head">
    <p class="eyebrow">Press &amp; News</p>
    <h1>Apollonia Space Updates</h1>
    <p class="lede">
      The latest announcements, press releases, and newsletters from
      our team. For media inquiries, please contact
      <a href="mailto:press@apollonia.space">press@apollonia.space</a>.
    </p>
  </header>
 
  <section class="filters" aria-label="Filter posts">
    <span class="filter-label">Filter by:</span>
    <div class="filter-buttons" role="tablist">
      <button type="button" class="filter is-active" data-filter="all" role="tab" aria-selected="true">
        All
      </button>
      <button type="button" class="filter" data-filter="press-release" role="tab" aria-selected="false">
        Press Release
      </button>
      <button type="button" class="filter" data-filter="newsletter" role="tab" aria-selected="false">
        Newsletter
      </button>
    </div>
    <button type="button" class="reset" data-reset>Reset</button>
  </section>
 
  <section class="grid" aria-live="polite">
    {sortedItems.map((item) => (
      <article class="card" data-category={slug(item.category)}>
        <div class="card-meta">
          <span class={`tag tag--${slug(item.category)}`}>{item.category}</span>
          <time datetime={item.date}>{formatDate(item.date)}</time>
        </div>
        <h2 class="card-title">
          <a href={item.url}>{item.title}</a>
        </h2>
        <p class="card-excerpt">{item.excerpt}</p>
        <a class="card-link" href={item.url}>
          Read more <span aria-hidden="true">→</span>
        </a>
      </article>
    ))}
  </section>
 
  <p class="empty" hidden>No posts match this filter yet.</p>
</main>
 
<SiteFooter />
 
<style>
  /* ─── Scoped to this page; uses neutral CSS vars that can inherit from globals ── */
  .press-news {
    --pn-fg: var(--color-fg, #111);
    --pn-fg-muted: var(--color-fg-muted, #555);
    --pn-bg: var(--color-bg, #fff);
    --pn-surface: var(--color-surface, #f6f6f4);
    --pn-border: var(--color-border, #e5e5e0);
    --pn-accent: var(--color-accent, #0b3d91); /* deep space blue, override in globals if needed */
    --pn-accent-soft: var(--color-accent-soft, #e7eef9);
 
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem) 6rem;
    color: var(--pn-fg);
    background: var(--pn-bg);
  }
 
  .page-head {
    max-width: 48rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
 
  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pn-fg-muted);
    margin: 0 0 1rem;
  }
 
  .page-head h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }
 
  .lede {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--pn-fg-muted);
    max-width: 38rem;
    margin: 0;
  }
 
  .lede a {
    color: var(--pn-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
 
  /* ─── Filters ─── */
  .filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0;
    margin-bottom: 2.5rem;
    border-top: 1px solid var(--pn-border);
    border-bottom: 1px solid var(--pn-border);
  }
 
  .filter-label {
    font-size: 0.875rem;
    color: var(--pn-fg-muted);
    margin-right: 0.25rem;
  }
 
  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
 
  .filter {
    appearance: none;
    border: 1px solid var(--pn-border);
    background: transparent;
    color: var(--pn-fg);
    font: inherit;
    font-size: 0.9375rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
 
  .filter:hover {
    border-color: var(--pn-fg);
  }
 
  .filter.is-active {
    background: var(--pn-fg);
    color: var(--pn-bg);
    border-color: var(--pn-fg);
  }
 
  .reset {
    appearance: none;
    background: none;
    border: 0;
    font: inherit;
    font-size: 0.875rem;
    color: var(--pn-fg-muted);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-left: auto;
    padding: 0.25rem 0;
  }
 
  .reset:hover {
    color: var(--pn-fg);
  }
 
  /* ─── Cards ─── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 1.5rem;
  }
 
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.75rem;
    background: var(--pn-surface);
    border: 1px solid var(--pn-border);
    border-radius: 4px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
 
  .card:hover {
    border-color: var(--pn-fg);
    transform: translateY(-2px);
  }
 
  .card[hidden] {
    display: none;
  }
 
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    color: var(--pn-fg-muted);
  }
 
  .tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.6rem;
    border-radius: 2px;
    background: var(--pn-bg);
    border: 1px solid var(--pn-border);
    color: var(--pn-fg);
  }
 
  .tag--press-release {
    background: var(--pn-accent-soft);
    border-color: transparent;
    color: var(--pn-accent);
  }
 
  .card-title {
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
  }
 
  .card-title a {
    color: inherit;
    text-decoration: none;
  }
 
  .card-title a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
 
  .card-excerpt {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--pn-fg-muted);
    margin: 0;
    flex: 1;
  }
 
  .card-link {
    align-self: flex-start;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--pn-fg);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
 
  .card-link span {
    display: inline-block;
    transition: transform 0.15s ease;
  }
 
  .card-link:hover span {
    transform: translateX(3px);
  }
 
  .empty {
    text-align: center;
    color: var(--pn-fg-muted);
    padding: 3rem 0;
    font-size: 1rem;
  }
 
  @media (max-width: 640px) {
    .reset {
      margin-left: 0;
    }
  }
</style>
 
<script>
  // Client-side filter
  const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter');
  const cards = document.querySelectorAll<HTMLElement>('.card');
  const resetButton = document.querySelector<HTMLButtonElement>('[data-reset]');
  const emptyState = document.querySelector<HTMLElement>('.empty');
 
  function applyFilter(value: string) {
    let visible = 0;
    cards.forEach((card) => {
      const match = value === 'all' || card.dataset.category === value;
      card.hidden = !match;
      if (match) visible++;
    });
    if (emptyState) emptyState.hidden = visible > 0;
 
    filterButtons.forEach((btn) => {
      const active = btn.dataset.filter === value;
      btn.classList.toggle('is-active', active);
      btn.setAttribute('aria-selected', String(active));
    });
  }
 
  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      applyFilter(btn.dataset.filter || 'all');
    });
  });
 
  resetButton?.addEventListener('click', () => applyFilter('all'));
</script>