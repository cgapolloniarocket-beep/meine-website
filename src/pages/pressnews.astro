---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';

// ─────────────────────────────────────────────────────────────────────────────
// EINTRÄGE PFLEGEN: Neue News einfach in dieses Array einfügen.
// Sortierung nach Datum übernimmt die Seite automatisch (neueste zuerst).
//
//   category: 'Press Release' oder 'Newsletter'
//   date:     ISO-Format YYYY-MM-DD
//   url:      Link zum vollständigen Artikel (extern oder eigene Seite)
// ─────────────────────────────────────────────────────────────────────────────

type Category = 'Press Release' | 'Newsletter';

interface NewsItem {
  title: string;
  category: Category;
  date: string;
  excerpt: string;
  url: string;
}

const items: NewsItem[] = [
  {
    title: 'To be disclosed',
    category: 'Press Release',
    date: '2026-05-14',
    excerpt: 'To be disclosed',
    url: '#',
  },
  {
    title: 'To be disclosed',
    category: 'Newsletter',
    date: '2026-04-28',
    excerpt: 'To be disclosed',
    url: '#',
  },
  {
    title: 'To be disclosed',
    category: 'Press Release',
    date: '2026-03-10',
    excerpt: 'To be disclosed',
    url: '#',
  }
];

const sortedItems = [...items].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });

const slug = (c: Category) => c.toLowerCase().replace(' ', '-');
const hasItems = sortedItems.length > 0;
---

<Layout title="Apollonia – Press & News">
  <section class="page-one">
    <SiteHeader transition:persist />

    <div class="hero-text">
      <h1>PRESS &amp; NEWS</h1>
      <p class="subtitle">The latest announcements, press releases, and newsletters from our team.</p>
    </div>

    <div class="main-content-area">
      {hasItems && (
        <section class="filters" aria-label="Filter posts">
          <span class="filter-label">Filter by</span>
          <div class="filter-buttons" role="tablist">
            <button type="button" class="filter is-active" data-filter="all" role="tab" aria-selected="true">All</button>
            <button type="button" class="filter" data-filter="press-release" role="tab" aria-selected="false">Press Release</button>
            <button type="button" class="filter" data-filter="newsletter" role="tab" aria-selected="false">Newsletter</button>
          </div>
          <button type="button" class="reset" data-reset>Reset</button>
        </section>
      )}

      {hasItems ? (
        <section class="grid" aria-live="polite">
          {sortedItems.map((item) => (
            <article class="card" data-category={slug(item.category)}>
              <div class="card-meta">
                <span class={`tag tag--${slug(item.category)}`}>{item.category}</span>
                <time datetime={item.date}>{formatDate(item.date)}</time>
              </div>
              <h3 class="card-title">
                <a href={item.url}>{item.title}</a>
              </h3>
              <p class="card-excerpt">{item.excerpt}</p>
              <a class="card-link" href={item.url}>
                Read more &rarr;
              </a>
            </article>
          ))}
        </section>
      ) : (
        <div class="coming-soon">
          <p>Coming soon</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .page-one {
    position: relative;
    min-height: 100vh;
    background-color: transparent;
  }

  /* ─── 1:1 Importierte Titel- & Subtitel-Eigenschaften aus Podcast ─── */
  .hero-text { 
    padding: 10rem 4rem 0; 
    position: relative; 
    z-index: 3; 
  }

  h1 {
    font-family: 'Barlow', sans-serif;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 0.95;
    color:rgb(255, 255, 255);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    color: rgb(255, 255, 255);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-left: 0.5rem;
    line-height: 1.5;
    max-width: 45%;
    margin-top: 1.5rem;
    margin-bottom: 0;
  }

  /* ─── Layout-Bereich für News-Inhalte ─── */
  .main-content-area {
    padding: 4rem 4rem 7rem;
  }

  /* Coming soon */
  .coming-soon {
    padding: clamp(4rem, 10vw, 8rem) 0;
    text-align: center;
  }

  .coming-soon p {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  /* Filters */
  .filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0;
    margin-bottom: 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .filter-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-right: 0.25rem;
  }

  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter {
    appearance: none;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.55rem 1.2rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  }

  .filter:hover {
    border-color: #42A5F5;
    color: #42A5F5;
  }

  .filter.is-active {
    background: #ffffff;
    color: #050d1a;
    border-color: #ffffff;
  }

  .reset {
    appearance: none;
    background: none;
    border: 0;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-left: auto;
    padding: 0.25rem 0;
    transition: color 0.25s ease;
  }

  .reset:hover {
    color: #42A5F5;
  }

  /* Grid & Cards (Farblich abgestimmt auf Podcast-Sektion) */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 2rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
    cursor: pointer;
  }

  .card:hover {
    border-color: rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.12);
  }

  .card[hidden] {
    display: none;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .tag {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.32rem 0.7rem;
    border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.85);
  }

  .tag--press-release {
    background: rgba(66, 165, 245, 0.12);
    border-color: rgba(66, 165, 245, 0.4);
    color: #42A5F5;
  }

  .tag--newsletter {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .card-title {
    font-family: 'Barlow', sans-serif;
    font-size: 1.2rem;
    line-height: 1.3;
    font-weight: 700;
    margin: 0;
    color: #ffffff;
  }

  .card-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .card-title a:hover {
    color: #42A5F5;
  }

  .card-excerpt {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    flex: 1;
    font-weight: 300;
  }

  .card-link {
    align-self: flex-start;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: #ffffff;
    text-decoration: none;
    padding-bottom: 3px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .card-link:hover {
    color: #42A5F5;
    border-color: #42A5F5;
  }

  /* ─── Media Queries (Ebenfalls aus Podcast gematcht) ─── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .subtitle { max-width: 50%; }
  }

  @media (max-width: 768px) {
    .hero-text { padding: 7rem 1.5rem 0; }
    h1 { font-size: 2.4rem; line-height: 1.05; }
    .subtitle { max-width: 100%; padding-left: 0; font-size: 0.8rem; }
    .main-content-area { padding: 2.5rem 1.5rem; }
    .grid { grid-template-columns: 1fr; }
    .filters { gap: 0.75rem; }
    .reset { margin-left: 0; }
  }

  @media (max-width: 380px) {
    .hero-text { padding: 6.5rem 1.2rem 0; }
    h1 { font-size: 2rem; }
    .main-content-area { padding: 2rem 1.2rem; }
  }
</style>

<script>
  function initPressNewsFilter() {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter');
    const cards = document.querySelectorAll<HTMLElement>('.card');
    const resetButton = document.querySelector<HTMLButtonElement>('[data-reset]');

    if (!filterButtons.length) return;

    function applyFilter(value: string) {
      cards.forEach((card) => {
        const match = value === 'all' || card.dataset.category === value;
        card.hidden = !match;
      });

      filterButtons.forEach((btn) => {
        const active = btn.dataset.filter === value;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-selected', String(active));
      });
    }

    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        applyFilter(btn.dataset.filter || 'all');
      });
    });

    resetButton?.addEventListener('click', () => applyFilter('all'));
  }

  document.addEventListener('astro:page-load', initPressNewsFilter);
</script>