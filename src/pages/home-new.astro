---
// home-new.astro — redesign preview route.
// Self-contained document (does NOT use the existing navy Layout.astro), so the
// new cream/serif brand system is fully isolated from the live site.
// Marked noindex so it doesn't compete with the live index.astro in search.
//
// NOTE: when this is promoted to the real front page, move this file's contents
// into src/pages/index.astro, drop the `noindex` line, and fill the OG/SEO
// placeholders below.
import '@fontsource/instrument-serif/400.css';
import '@fontsource-variable/inter';
import '../styles/tokens.css';
import '../styles/global.css';

import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Technology from '../components/Technology.astro';
import WhyItMatters from '../components/WhyItMatters.astro';
import Team from '../components/Team.astro';
import Updates from '../components/Updates.astro';
import Footer from '../components/Footer.astro';

const title = 'Apollonia Space — [PLACEHOLDER_TAGLINE]';
const description = '[PLACEHOLDER_META_DESCRIPTION — ≤155 chars]';
const url = 'https://www.apolloniaspace.com/';
const ogImage = '[PLACEHOLDER_OG_IMAGE_PATH]'; /* 1200×630 */
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Preview route: keep out of the index while the live site is the navy one -->
    <meta name="robots" content="noindex" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Apollonia Space" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons. The SVG is the Spike mark and scales to every size; the PNG
         covers apple-touch-icon. Generate dedicated 32/180/192/512 PNGs before
         launch if you want raster fallbacks (see deliverable notes). -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/apollonia_logo_white_black.png" />
    <link rel="apple-touch-icon" href="/apollonia_logo_white_black.png" />

    <link rel="canonical" href={url} />
  </head>
  <body>
    <Nav />
    <main>
      <Hero />
      <Technology />
      <WhyItMatters />
      <Team />
      <Updates />
    </main>
    <Footer />
  </body>
</html>
