---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---
<Layout title="Apollonia – Imprint">
  <div class="stars">
    {Array.from({length: 30}).map((_, i) => (
      <div class="star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 4}s; --size: ${Math.random() * 2 + 1}px;`} />
    ))}
  </div>
  <SiteHeader />
  <main>
    <h1>Imprint</h1>
    <div class="imprint-content">
      <p><strong>Apollonia Space</strong></p>
      <p>Caspar </p>
      <p>M</p>
      <p>10</p>
      <p>Email: contact@apolloniaspace.com</p>
    </div>
  </main>
</Layout>
<style>
  .stars { position: fixed; inset: 0; pointer-events: none; }
  .star { position: absolute; left: var(--x); top: var(--y); width: var(--size); height: var(--size); background: #ffffff; border-radius: 50%; opacity: 0; animation: twinkle 3s var(--delay) infinite ease-in-out; }
  @keyframes twinkle { 0%, 100% { opacity: 0; } 50% { opacity: 0.8; } }
  main { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 8rem 4rem 4rem; position: relative; }
  h1 { font-family: 'Montserrat', sans-serif; font-size: 2rem; font-weight: 400; text-transform: uppercase; letter-spacing: 0.1em; color: #ffffff; margin-bottom: 3rem; }
  .imprint-content p { font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 300; color: rgba(255, 255, 255, 0.7); line-height: 1.8; margin-bottom: 0.5rem; }
  .imprint-content strong { font-weight: 500; color: #ffffff; }
</style>
---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

