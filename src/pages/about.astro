---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout title="Apollonia – Imprint">

  <div class="stars">
    {Array.from({length: 30}).map((_, i) => (
      <div class="star" style={`--x: ${Math.random() * 100}%; --y: ${Math.random() * 100}%; --delay: ${Math.random() * 4}s; --size: ${Math.random() * 2 + 1}px;`} />
    ))}
  </div>

  <div class="comet-container">
    <div class="comet"></div>
  </div>

  <SiteHeader />


</Layout>

<style>
  .stars {
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: #ffffff;
    border-radius: 50%;
    opacity: 0;
    animation: twinkle 3s var(--delay) infinite ease-in-out;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.8; }
  }

  .comet-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 1;
  }

  .comet {
    position: absolute;
    top: -5%;
    right: -10%;
    width: 12px;
    height: 12px;
    background: radial-gradient(circle, #ffffff, rgba(120, 255, 160, 0.8), transparent);
    border-radius: 50%;
    box-shadow:
      0 0 15px 8px rgba(120, 255, 160, 0.7),
      0 0 40px 15px rgba(80, 220, 120, 0.4),
      0 0 80px 30px rgba(40, 180, 80, 0.2);
    opacity: 0;
    animation: cometFly 120s 3s infinite linear;
  }

  .comet::before {
    content: '';
    position: absolute;
    top: 3px;
    right: 12px;
    width: 600px;
    height: 3px;
    background: linear-gradient(to left, rgba(120, 255, 160, 0.7), rgba(60, 200, 100, 0.3) 30%, rgba(30, 150, 70, 0.1) 60%, transparent);
    transform-origin: right center;
    transform: rotate(0deg);
    filter: blur(0.5px);
  }

  .comet::after {
    content: '';
    position: absolute;
    top: -2px;
    right: 10px;
    width: 400px;
    height: 16px;
    background: linear-gradient(to left, rgba(80, 220, 120, 0.2), rgba(40, 160, 80, 0.05) 40%, transparent);
    transform-origin: right center;
    filter: blur(4px);
  }

  @keyframes cometFly {
    0% {
      opacity: 0;
      top: -5%;
      right: -10%;
    }
    1% {
      opacity: 1;
    }
    15% {
      opacity: 1;
      top: 85%;
      right: 110%;
    }
    16% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  main {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem 4rem 4rem;
    position: relative;
    z-index: 2;
  }

  h1 {
    font-family: 'Montserrat', sans-serif;
    font-size: 2rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #ffffff;
    margin-bottom: 3rem;
  }

  .imprint-content p {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.8;
    margin-bottom: 0.5rem;
  }

  .imprint-content strong {
    font-weight: 500;
    color: #ffffff;
  }

  .imprint-content .small {
    margin-top: 2rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
  }
</style>